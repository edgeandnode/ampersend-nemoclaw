# 1claw — required for vault access (get from https://1claw.xyz)
ONECLAW_VAULT_ID=
ONECLAW_AGENT_ID=
ONECLAW_API_KEY=

# Optional: use a static JWT instead of agent_id + api_key (skips auth exchange)
# ONECLAW_TOKEN=

# Optional overrides (defaults: https://api.1claw.xyz, https://mcp.1claw.xyz/mcp)
# ONECLAW_BASE_URL=https://api.1claw.xyz
# ONECLAW_MCP_URL=https://mcp.1claw.xyz/mcp
# ONECLAW_USE_SHROUD=false

# NemoClaw / OpenShell sandbox name (used by setup:docker)
SANDBOX_NAME=my-assistant

# Optional: NVIDIA API key for NemoClaw inference (prompted by install if not set)
# NVIDIA_API_KEY=
